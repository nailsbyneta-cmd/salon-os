// SALON OS — Prisma Schema
// Phase 1 Modul 1 (Calendar & Scheduling): Kernentitäten für Multi-Tenant +
// Auth + Staff + Services + Appointments + Clients + Rooms + Shifts.
//
// Vollständiges Zielschema: siehe specs/data-model.md.
// Jede tenant-skoped Tabelle MUSS RLS haben — enforced via SQL-Migrations
// unter prisma/migrations/*/migration.sql.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, pg_trgm, unaccent, vector]
}

// ─── Multi-Tenancy ─────────────────────────────────────────────

model Tenant {
  id           String       @id @default(uuid()) @db.Uuid
  slug         String       @unique
  name         String
  legalName    String?
  countryCode  String       @db.Char(2)
  currency     String       @db.Char(3)
  timezone     String
  locale       String
  vatId        String?
  plan         Plan         @default(STARTER)
  status       TenantStatus @default(TRIAL)
  billingEmail String?
  // Public-Branding (Diff #18 — Kunden-Homepage-Felder)
  tagline          String?
  description      String?
  logoUrl          String?
  heroImageUrl     String?
  brandColor       String?
  instagramUrl     String?
  facebookUrl      String?
  tiktokUrl        String?
  whatsappE164     String?
  googleBusinessUrl String?
  // Tenant-Settings als JSON — flexibel für alle Customizations:
  // Booking-Policy, Notification-Templates, Plan-Limits, Feature-Flags.
  // Schema: { booking: {...}, notifications: {...}, features: {...} }
  settings         Json?        @default("{}")
  createdAt    DateTime     @default(now()) @db.Timestamptz
  updatedAt    DateTime     @updatedAt @db.Timestamptz
  deletedAt    DateTime?    @db.Timestamptz

  locations        Location[]
  memberships      TenantMembership[]
  auditLogs        AuditLog[]
  staff            Staff[]
  serviceCategories ServiceCategory[]
  services         Service[]
  serviceOptionGroups ServiceOptionGroup[]
  serviceOptions      ServiceOption[]
  serviceAddOns       ServiceAddOn[]
  serviceBundlesOut   ServiceBundle[]
  appointmentSeries   AppointmentSeries[]
  clients          Client[]
  clientMagicLinks ClientMagicLink[]
  clientSessions   ClientSession[]
  appointments     Appointment[]
  giftCards        GiftCard[]
  waitlistEntries  WaitlistEntry[]
  products         Product[]
  faqs             SalonFAQ[]
  reviews          SalonReview[]
  galleryImages    SalonGalleryImage[]

  @@index([status])
  @@map("tenant")
}

// ─── Public Salon-Homepage: FAQ, Reviews, Gallery ─────────────

model SalonFAQ {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  question  String
  answer    String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, order])
  @@map("salon_faq")
}

model SalonReview {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  authorName String
  rating     Int      // 1-5
  text       String
  sourceUrl  String?
  featured   Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, featured, createdAt])
  @@map("salon_review")
}

model SalonGalleryImage {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  imageUrl  String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, order])
  @@map("salon_gallery_image")
}

model GiftCard {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  code           String    @unique
  amount         Decimal   @db.Decimal(10, 2)
  balance        Decimal   @db.Decimal(10, 2)
  currency       String    @default("CHF") @db.Char(3)
  purchasedById  String?   @db.Uuid
  purchasedAt    DateTime  @default(now()) @db.Timestamptz
  redeemedAt     DateTime? @db.Timestamptz
  expiresAt      DateTime? @db.Timestamptz
  recipientEmail String?
  recipientName  String?
  message        String?
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz

  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchasedBy  Client? @relation(fields: [purchasedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([code])
  @@map("gift_card")
}

model Product {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @db.Uuid
  name        String
  sku         String?
  brand       String?
  category    String?
  barcode     String?
  type        String    @default("RETAIL")
  unit        String?
  costCents   Int       @default(0)
  retailCents Int       @default(0)
  currency    String    @default("CHF") @db.Char(3)
  stockLevel  Int       @default(0)
  reorderAt   Int       @default(0)
  reorderQty  Int       @default(0)
  supplier    String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  deletedAt   DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, stockLevel, reorderAt])
  @@map("product")
}

model WaitlistEntry {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  clientId         String   @db.Uuid
  serviceId        String   @db.Uuid
  locationId       String   @db.Uuid
  preferredStaffId String?  @db.Uuid
  earliestAt       DateTime @db.Timestamptz
  latestAt         DateTime @db.Timestamptz
  notes            String?
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now()) @db.Timestamptz
  updatedAt        DateTime @updatedAt @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  staff    Staff?   @relation(fields: [preferredStaffId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, earliestAt])
  @@map("waitlist_entry")
}

enum Plan {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
  MEDSPA
}

enum TenantStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

// ─── Locations ─────────────────────────────────────────────────

model Location {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  name              String
  slug              String
  address1          String?
  address2          String?
  city              String?
  postalCode        String?
  region            String?
  countryCode       String   @db.Char(2)
  latitude          Decimal? @db.Decimal(10, 7)
  longitude         Decimal? @db.Decimal(10, 7)
  phone             String?
  email             String?
  timezone          String
  currency          String   @db.Char(3)
  taxConfig         Json
  openingHours      Json
  publicProfile     Boolean  @default(true)
  marketplaceListed Boolean  @default(false)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz
  deletedAt         DateTime? @db.Timestamptz

  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms               Room[]
  staffAssignments    StaffLocation[]
  serviceVariants     ServiceVariant[]
  appointments        Appointment[]
  appointmentSeries   AppointmentSeries[]
  shifts              Shift[]
  waitlistEntries     WaitlistEntry[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("location")
}

model Room {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  locationId String   @db.Uuid
  name       String
  capacity   Int      @default(1)
  features   String[] @default([])
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  location     Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId, locationId])
  @@map("room")
}

// ─── Users + Memberships ───────────────────────────────────────

model User {
  id           String     @id @default(uuid()) @db.Uuid
  workosUserId String?    @unique
  email        String     @unique
  firstName    String?
  lastName     String?
  locale       String?
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @db.Timestamptz
  createdAt    DateTime   @default(now()) @db.Timestamptz
  updatedAt    DateTime   @updatedAt @db.Timestamptz

  memberships TenantMembership[]
  staff       Staff[]

  @@map("user")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

model TenantMembership {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @db.Uuid
  userId    String    @db.Uuid
  role      StaffRole
  isPrimary Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_membership")
}

enum StaffRole {
  OWNER
  MANAGER
  FRONT_DESK
  STYLIST
  BOOTH_RENTER
  TRAINEE
  ASSISTANT
}

// ─── Staff (Mitarbeitende) ─────────────────────────────────────
// Ein Staff-Record repräsentiert die "Arbeits-Seite" einer Person.
// Die Auth-Seite ist User. Ein User kann mehreren Staff-Records entsprechen,
// z. B. Booth-Renter in 2 Tenants. Typisch aber: 1:1.

model Staff {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @db.Uuid
  userId          String         @db.Uuid
  firstName       String
  lastName        String
  displayName     String?
  email           String
  phone           String?
  role            StaffRole
  employmentType  EmploymentType
  commissionRate  Decimal?       @db.Decimal(5, 2)
  boothRent       Decimal?       @db.Decimal(10, 2)
  hourlyRate      Decimal?       @db.Decimal(10, 2)
  color           String?
  photoUrl        String?
  bio             String?
  startsAt        DateTime?      @db.Timestamptz
  // Wöchentliche Schicht-Vorlage: { mon: [{open,close}], tue: [], ... }
  // Gleiche Shape wie location.openingHours. Wenn gesetzt, hat Vorrang
  // vor location.openingHours bei Shift-Generierung.
  weeklySchedule  Json?
  // Ausnahme-Tage: { 'YYYY-MM-DD': { closed: true } | { intervals: [{open,close}] } }
  // Überschreibt weeklySchedule für das jeweilige Datum. Einzeltermine
  // (Arzt, kürzere Schicht, Zusatz-Samstag). Kein Auto-Cleanup; User
  // verwaltet Einträge manuell.
  scheduleExceptions Json?       @default("{}")
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now()) @db.Timestamptz
  updatedAt       DateTime       @updatedAt @db.Timestamptz
  deletedAt       DateTime?      @db.Timestamptz

  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationAssignments StaffLocation[]
  services            StaffService[]
  shifts              Shift[]
  timeOff             TimeOff[]
  appointments        Appointment[]
  appointmentItems    AppointmentItem[]
  appointmentSeries   AppointmentSeries[]
  waitlistEntries     WaitlistEntry[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@map("staff")
}

enum EmploymentType {
  EMPLOYEE
  CONTRACTOR
  BOOTH_RENTER
  COMMISSION
  OWNER
}

model StaffLocation {
  staffId    String  @db.Uuid
  locationId String  @db.Uuid
  isPrimary  Boolean @default(false)

  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([staffId, locationId])
  @@map("staff_location")
}

// ─── Services ──────────────────────────────────────────────────

model ServiceCategory {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @db.Uuid
  name     String
  order    Int    @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]

  @@index([tenantId])
  @@map("service_category")
}

model Service {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  categoryId        String   @db.Uuid
  name              String
  slug              String
  description       String?
  durationMinutes   Int
  bufferBeforeMin   Int      @default(0)
  bufferAfterMin    Int      @default(0)
  basePrice         Decimal  @db.Decimal(10, 2)
  taxClass          String?
  bookable          Boolean  @default(true)
  requiresConsult   Boolean  @default(false)
  requiresPatchTest Boolean  @default(false)
  gender            Gender?
  color             String?
  order             Int      @default(0)
  minDepositAmount  Decimal? @db.Decimal(10, 2)
  minDepositPct     Decimal? @db.Decimal(5, 2)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz
  deletedAt         DateTime? @db.Timestamptz

  processingTimeMin Int      @default(0)
  activeTimeBefore  Int      @default(0)
  activeTimeAfter   Int      @default(0)

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category   ServiceCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants   ServiceVariant[]
  staffLinks StaffService[]
  appointmentItems  AppointmentItem[]
  waitlistEntries   WaitlistEntry[]
  optionGroups      ServiceOptionGroup[]
  addOns            ServiceAddOn[]
  bundlesAsPrimary  ServiceBundle[] @relation("bundlePrimary")
  bundlesAsBundled  ServiceBundle[] @relation("bundleBundled")
  appointmentSeries AppointmentSeries[]

  @@unique([tenantId, slug])
  @@index([tenantId, categoryId])
  @@map("service")
}

// Option-Groups auf einem Service: ein Kunde wählt pro Gruppe eine Option.
// Beispiel Nägel: Gruppen = Typ (Gel/Acryl), Modus (Neu/Auffüllen), Länge.
// Der Mangomint-Stil: jede Option hat Preis-/Dauer-/Processing-Delta.
model ServiceOptionGroup {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @db.Uuid
  serviceId  String  @db.Uuid
  name       String  // z.B. "Typ", "Länge"
  required   Boolean @default(true)
  multi      Boolean @default(false)  // Multi-Select erlauben (später)
  sortOrder  Int     @default(0)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  options ServiceOption[]

  @@index([tenantId, serviceId])
  @@map("service_option_group")
}

model ServiceOption {
  id                    String  @id @default(uuid()) @db.Uuid
  tenantId              String  @db.Uuid
  groupId               String  @db.Uuid
  label                 String  // z.B. "Gel", "Kurz"
  priceDelta            Decimal @default(0) @db.Decimal(10, 2)
  durationDeltaMin      Int     @default(0)
  processingDeltaMin    Int     @default(0)
  isDefault             Boolean @default(false)
  sortOrder             Int     @default(0)
  createdAt             DateTime @default(now()) @db.Timestamptz
  updatedAt             DateTime @updatedAt @db.Timestamptz

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  group  ServiceOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([tenantId, groupId])
  @@map("service_option")
}

// Add-Ons (Phorest-Stil): zusätzliche Services, die mit einem Primär-Service
// gebucht werden (French, Paraffin, LED-Therapie etc.). Können 0 Min haben.
model ServiceAddOn {
  id                 String  @id @default(uuid()) @db.Uuid
  tenantId           String  @db.Uuid
  serviceId          String  @db.Uuid  // der Primär-Service auf dem das Add-On angeboten wird
  name               String
  priceDelta         Decimal @default(0) @db.Decimal(10, 2)
  durationDeltaMin   Int     @default(0)
  sortOrder          Int     @default(0)
  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([tenantId, serviceId])
  @@map("service_addon")
}

// Bundle-Upsell: wenn Kunde den primaryService bucht, schlägt der Wizard
// den bundledService mit Rabatt dazu vor. Beispiel: Nails + Pediküre Basis
// = -5 CHF. Zwei Services, ein Rabatt, upsell-optimiert.
model ServiceBundle {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  primaryServiceId  String   @db.Uuid
  bundledServiceId  String   @db.Uuid
  label             String   // "+ Pediküre dazu — für nur CHF 34 (statt 39)"
  discountAmount    Decimal? @db.Decimal(10, 2) // flat Rabatt, alternativ:
  discountPct       Decimal? @db.Decimal(5, 2)  // prozentualer Rabatt
  active            Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  primaryService  Service @relation("bundlePrimary", fields: [primaryServiceId], references: [id], onDelete: Cascade)
  bundledService  Service @relation("bundleBundled", fields: [bundledServiceId], references: [id], onDelete: Cascade)

  @@index([tenantId, primaryServiceId, active])
  @@map("service_bundle")
}

enum Gender {
  FEMALE
  MALE
  NEUTRAL
  KIDS
}

model ServiceVariant {
  id              String  @id @default(uuid()) @db.Uuid
  tenantId        String  @db.Uuid
  locationId      String  @db.Uuid
  serviceId       String  @db.Uuid
  price           Decimal @db.Decimal(10, 2)
  durationMinutes Int?
  active          Boolean @default(true)

  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, serviceId])
  @@index([tenantId])
  @@map("service_variant")
}

model StaffService {
  staffId          String   @db.Uuid
  serviceId        String   @db.Uuid
  priceOverride    Decimal? @db.Decimal(10, 2)
  durationOverride Int?

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_service")
}

// ─── Clients ───────────────────────────────────────────────────

model Client {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  firstName        String
  lastName         String
  email            String?
  phone            String?
  phoneE164        String?
  birthday         DateTime? @db.Date
  pronouns         String?
  photoUrl         String?
  address          Json?
  language         String?   @default("de-CH")
  marketingOptIn   Boolean   @default(false)
  smsOptIn         Boolean   @default(false)
  emailOptIn       Boolean   @default(false)
  notesInternal    String?
  allergies        String[]  @default([])
  tags             String[]  @default([])
  preferredStaffId String?   @db.Uuid
  noShowRisk       Decimal?  @db.Decimal(5, 2)
  lifetimeValue    Decimal   @default(0) @db.Decimal(12, 2)
  lastVisitAt      DateTime? @db.Timestamptz
  totalVisits      Int       @default(0)
  blocked          Boolean   @default(false)
  familyParentId   String?   @db.Uuid
  source           String?
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  deletedAt        DateTime? @db.Timestamptz

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  appointmentSeries AppointmentSeries[]
  giftCards       GiftCard[]
  waitlistEntries WaitlistEntry[]
  magicLinks      ClientMagicLink[]
  sessions        ClientSession[]
  family          Client[]        @relation("Family")
  parent          Client?         @relation("Family", fields: [familyParentId], references: [id])

  @@index([tenantId, phoneE164])
  @@index([tenantId, email])
  @@index([tenantId, lastVisitAt])
  @@map("client")
}

// ─── Appointments ──────────────────────────────────────────────

model Appointment {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String            @db.Uuid
  locationId        String            @db.Uuid
  clientId          String?           @db.Uuid
  staffId           String            @db.Uuid
  roomId            String?           @db.Uuid
  status            AppointmentStatus @default(BOOKED)
  startAt           DateTime          @db.Timestamptz
  endAt             DateTime          @db.Timestamptz
  bookedAt          DateTime          @default(now()) @db.Timestamptz
  bookedVia         BookingChannel    @default(STAFF_INTERNAL)
  notes             String?
  internalNotes     String?
  depositAmount     Decimal?          @db.Decimal(10, 2)
  depositPaid       Boolean           @default(false)
  depositPaidAt     DateTime?         @db.Timestamptz
  tipAmount         Decimal?          @db.Decimal(10, 2)
  paidAt            DateTime?         @db.Timestamptz
  paymentMethod     String?
  cancelledAt       DateTime?         @db.Timestamptz
  cancelReason      String?
  noShow            Boolean           @default(false)
  rescheduledFromId String?           @db.Uuid
  checkedInAt       DateTime?         @db.Timestamptz
  completedAt       DateTime?         @db.Timestamptz
  sourceCampaignId  String?           @db.Uuid
  language          String?
  // Wenn Termin Teil einer Serie ist (Recurring/Stamm-Kundin):
  seriesId          String?           @db.Uuid
  occurrenceIndex   Int?              // 1-based Position in der Serie
  createdAt         DateTime          @default(now()) @db.Timestamptz
  updatedAt         DateTime          @updatedAt @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Restrict)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Restrict)
  room     Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)
  items    AppointmentItem[]
  series   AppointmentSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([tenantId, startAt])
  @@index([tenantId, staffId, startAt])
  @@index([tenantId, clientId, startAt])
  @@index([tenantId, status])
  @@index([seriesId])
  @@map("appointment")
}

// Recurring Appointments — "Stamm-Kundin alle 4 Wochen Auffüllen".
// Generator legt initial 3 Termine an, Cron-Job rollt nach.
// Edit-Modi: this-only / this-and-following / all (Google-Calendar-Pattern).
model AppointmentSeries {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  clientId        String   @db.Uuid
  staffId         String   @db.Uuid
  serviceId       String   @db.Uuid
  locationId      String   @db.Uuid
  // Frequenz: alle N Wochen (2/3/4/6/8 typisch)
  intervalWeeks   Int
  // Erste Occurrence (UTC)
  firstStartAt    DateTime @db.Timestamptz
  // Dauer in Minuten (gefroren bei Series-Creation, immune gegen
  // Service-Preis-Änderungen)
  durationMinutes Int
  // Ende: null = unendlich, sonst date oder occurrences
  endsAt          DateTime? @db.Timestamptz
  occurrences     Int?      // wenn gesetzt: nach N Occurrences stoppen
  // Generierungs-Status
  active          Boolean  @default(true)
  lastGeneratedAt DateTime? @db.Timestamptz   // wann zuletzt vorgebucht
  generatedUntil  DateTime? @db.Timestamptz   // bis wohin Termine existieren
  notes           String?
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Restrict)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Restrict)
  appointments Appointment[]

  @@index([tenantId, clientId, active])
  @@index([tenantId, active, lastGeneratedAt])
  @@map("appointment_series")
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  CHECKED_IN
  IN_SERVICE
  COMPLETED
  CANCELLED
  NO_SHOW
  WAITLIST
}

enum BookingChannel {
  ONLINE_BRANDED
  ONLINE_WIDGET
  MARKETPLACE
  INSTAGRAM
  FACEBOOK
  GOOGLE_RESERVE
  TIKTOK
  WHATSAPP
  PHONE_AI
  PHONE_MANUAL
  SMS
  WALK_IN
  STAFF_INTERNAL
}

model AppointmentItem {
  id            String   @id @default(uuid()) @db.Uuid
  appointmentId String   @db.Uuid
  serviceId     String   @db.Uuid
  staffId       String   @db.Uuid
  price         Decimal  @db.Decimal(10, 2)
  duration      Int
  taxClass      String?
  notes         String?
  /// Wizard-Variant-Labels (z.B. ["Mittel", "Gel"]) — Stylistin sieht im
  /// Kalender direkt was die Kundin gewählt hat ohne Klick auf den Termin.
  optionLabels  String[] @default([])

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staff       Staff       @relation(fields: [staffId], references: [id], onDelete: Restrict)

  @@index([appointmentId])
  @@map("appointment_item")
}

// ─── Staff Scheduling ──────────────────────────────────────────

model Shift {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid
  staffId    String   @db.Uuid
  locationId String   @db.Uuid
  startAt    DateTime @db.Timestamptz
  endAt      DateTime @db.Timestamptz
  isOpen     Boolean  @default(false)
  claimedAt  DateTime? @db.Timestamptz
  createdAt  DateTime @default(now()) @db.Timestamptz

  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([tenantId, staffId, startAt])
  @@map("shift")
}

model TimeOff {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  staffId   String   @db.Uuid
  startAt   DateTime @db.Timestamptz
  endAt     DateTime @db.Timestamptz
  reason    String?
  status    TimeOffStatus @default(PENDING)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([tenantId, staffId, startAt])
  @@map("time_off")
}

enum TimeOffStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Audit-Log (append-only) ───────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String?  @db.Uuid
  actorId   String?  @db.Uuid
  actorType String?
  entity    String
  entityId  String
  action    String
  diff      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamptz

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_log")
}

// ─── Outbox Events (reliable messaging) ───────────────────────

/// Customer-Session — wird beim Magic-Link-Verify erstellt, hält 30 Tage.
/// Token-Hash (sha256) statt Plaintext. Bei jedem API-Call wird lastSeenAt
/// aktualisiert (Sliding-Window). Logout = usedAt setzen oder Row löschen.
model ClientSession {
  id          String    @id @default(uuid()) @db.Uuid
  tokenHash   String    @unique
  clientId    String    @db.Uuid
  tenantId    String    @db.Uuid
  expiresAt   DateTime  @db.Timestamptz
  lastSeenAt  DateTime? @db.Timestamptz
  revokedAt   DateTime? @db.Timestamptz
  userAgent   String?
  createdAt   DateTime  @default(now()) @db.Timestamptz

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([clientId])
  @@map("client_session")
}

/// Magic-Link für Kundinnen-Selbst-Service. Kundin gibt Email ein, kriegt
/// Link, klickt → eingeloggt für 30 Tage (Cookie). Für /me/termine,
/// DSGVO-Export, Termin-Cancel/Reschedule. Token einmal verwendbar.
model ClientMagicLink {
  id        String    @id @default(uuid()) @db.Uuid
  tokenHash String    @unique
  clientId  String    @db.Uuid
  tenantId  String    @db.Uuid
  email     String
  expiresAt DateTime  @db.Timestamptz
  usedAt    DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([clientId, createdAt])
  @@map("client_magic_link")
}

model OutboxEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @db.Uuid
  type        String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int      @default(0)
  lastError   String?
  processedAt DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz

  @@index([status, createdAt])
  @@index([tenantId, type, createdAt])
  @@map("outbox_event")
}

enum OutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}
