{
  "name": "@salon-os/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema, migrations, and typed client for SALON OS.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "prisma"
  ],
  "scripts": {
    "postinstall": "node -e \"try{require('fs').accessSync('prisma/schema.prisma')}catch(e){process.exit(1)}\" && prisma generate || true",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx --env-file=../../.env prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "setup:ads": "tsx --env-file=../../.env prisma/seed-ads-integration.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@salon-os/utils": "workspace:*"
  },
  "devDependencies": {
    "@salon-os/config": "workspace:*",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx --env-file=../../.env prisma/seed.ts"
  }
}
