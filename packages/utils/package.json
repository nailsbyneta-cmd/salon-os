{
  "name": "@salon-os/utils",
  "version": "0.0.0",
  "private": true,
  "description": "Shared utilities — money, date/tz, phone, logger, id.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./timezone": {
      "types": "./dist/timezone.d.ts",
      "default": "./dist/timezone.js"
    },
    "./money": {
      "types": "./dist/money.d.ts",
      "default": "./dist/money.js"
    },
    "./phone": {
      "types": "./dist/phone.d.ts",
      "default": "./dist/phone.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0"
  },
  "devDependencies": {
    "@salon-os/config": "workspace:*",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
