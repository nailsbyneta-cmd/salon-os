{
  "name": "@salon-os/api",
  "version": "0.0.0",
  "private": true,
  "description": "SALON OS Backend API — NestJS + Fastify + Prisma",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:contract:provider": "vitest run --config vitest.contract.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.56.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@salon-os/auth": "workspace:*",
    "@salon-os/db": "workspace:*",
    "@salon-os/types": "workspace:*",
    "@salon-os/utils": "workspace:*",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "stripe": "^17.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@pact-foundation/pact": "^15.0.1",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.2",
    "testcontainers": "^10.16.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
