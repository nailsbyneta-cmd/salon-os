{
  "name": "@salon-os/worker",
  "version": "0.0.0",
  "private": true,
  "description": "BullMQ background workers — reminders, emails, exports, receipts, retries.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
