    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@salon-os/config": "workspace:*",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
