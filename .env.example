# SALON OS — example env file. Copy to .env and fill.
# In production, secrets live in Doppler; .env is local dev only.

# ─── Core ──────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── Database (Docker Compose defaults) ────────────────────────
DATABASE_URL=postgresql://salon:salon@localhost:5432/salon_os?schema=public
DIRECT_URL=postgresql://salon:salon@localhost:5432/salon_os?schema=public

# ─── Redis / Queues ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (WorkOS) ─────────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=

# ─── Payments (Stripe — primary) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (Postmark for transactional, Resend for marketing) ──
POSTMARK_SERVER_TOKEN=
RESEND_API_KEY=

# ─── SMS / Voice / WhatsApp (Twilio) ───────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# ─── Object Storage (Minio locally, S3/R2 in prod) ─────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-central-2
S3_BUCKET=salon-os-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ─── AI (OpenAI primary, Anthropic fallback) ───────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Observability ─────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_API_KEY=
DATADOG_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ─── Feature flags (GrowthBook) ────────────────────────────────
GROWTHBOOK_API_HOST=
GROWTHBOOK_CLIENT_KEY=

# ─── Fiscal (fiskaly — DE/AT TSE) ──────────────────────────────
FISKALY_API_KEY=
FISKALY_API_SECRET=

# ─── URLs ──────────────────────────────────────────────────────
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:4000
PUBLIC_MARKETPLACE_URL=http://localhost:3001
